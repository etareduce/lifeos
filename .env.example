# Copy to .env before running:
#   cp .env.example .env

# Optional AI features
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview

# Google OAuth (required only for Google Calendar integration)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Leave blank to auto-detect from request host (recommended for local dev).
GOOGLE_OAUTH_REDIRECT_URI=
GOOGLE_OAUTH_SCOPES=openid email profile https://www.googleapis.com/auth/calendar.readonly

# App/database
DATABASE_URL=sqlite+aiosqlite:///./elastisched.db
